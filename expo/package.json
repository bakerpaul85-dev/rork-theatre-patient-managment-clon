  "scripts": {
    "start": "bunx rork start -p ecqra2znxssw7mr4bzfq8 --tunnel",
    "start-web": "bunx rork start -p ecqra2znxssw7mr4bzfq8 --web --tunnel",
    "start-web-dev": "DEBUG=expo* bunx rork start -p ecqra2znxssw7mr4bzfq8 --web --tunnel",
    "start:dev-client": "bunx expo start --dev-client",
    "build:dev:ios": "bunx eas build --profile development --platform ios",
    "build:dev:android": "bunx eas build --profile development --platform android",
    "build:preview:ios": "bunx eas build --profile preview --platform ios",
    "build:preview:android": "bunx eas build --profile preview --platform android",
    "build:prod:ios": "bunx eas build --profile production --platform ios",
    "build:prod:android": "bunx eas build --profile production --platform android",
    "build:ios": "bunx expo run:ios",
    "build:android": "bunx expo run:android",
    "prebuild": "bunx expo prebuild",
    "lint": "expo lint",
    "postinstall": "node -e \"const fs = require('fs'); const path = require('path'); const target = path.join(process.cwd(), 'node_modules', '@teovilla', 'react-native-web-maps', 'node_modules', 'expo-location'); const source = path.join(process.cwd(), 'node_modules', 'expo-location'); if (fs.existsSync(target)) { fs.rmSync(target, { recursive: true, force: true }); fs.symlinkSync(path.relative(path.dirname(target), source), target, 'dir'); }\""
  },
